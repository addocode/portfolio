RewriteEngine On

# .php entfernen (Redirect)
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?]
RewriteRule ^ /%1 [R=301,L]

# Intern auf .php mappen
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# Portfolio Case Studies dynamisch
RewriteRule ^portfolio/([a-zA-Z0-9-]+)/?$ pages/portfolio-$1.php [L]